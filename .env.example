# Copy this file to .env for local testing only (e.g. with `vercel dev`).
# In production, set these as Environment Variables in the Vercel project
# dashboard instead — do NOT commit real values to git.

# Shared secret you choose yourself (any random string) when creating the
# webhook in the Student_Portal GitHub repo's Settings -> Webhooks. Enter
# the exact same value in both places. Used to verify the
# X-Hub-Signature-256 header via HMAC-SHA256.
GITHUB_WEBHOOK_SECRET=

# GitHub Personal Access Token with `repo` scope, used to POST a
# repository_dispatch event to VibhavKul/Student_Portal_Automation.
GITHUB_PAT=
